      "patch_vram_font_chunk_table_dual_slot_probe.py",
      "patch_vram_font_chunk_table_immediate_cache_probe.py",
      "patch_vram_font_chunk_table_miss_consumer_probe.py",
      "patch_vram_font_chunk_table_miss_flag_probe.py",
      "patch_vram_font_chunk_table_probe.py",
      "patch_vram_font_chunk_table_resident_copy_probe.py",
      "patch_vram_font_chunk_table_slim_moved_probe.py",
