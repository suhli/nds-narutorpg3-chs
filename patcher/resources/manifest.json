{
  "version": 1,
  "resource_set": "structaudit_v1",
  "text": {
    "frozen_translation": "text/frozen_translation.tsv",
    "code_table": "text/zh_code_table.tsv",
    "font_manifest_json": "text/font_manifest.json",
    "font_manifest_txt": "text/font_manifest.txt",
    "charset": "text/zh_charset.txt",
    "struct_adjusted_preview": "text/encoded-preview-struct-adjusted.tsv",
